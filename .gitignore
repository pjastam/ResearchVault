# macOS systeembestanden
.DS_Store
**/.DS_Store

# Obsidian-instellingen (machine-specifiek, niet deelbaar)
.obsidian/

# Claude Code lokale instellingen (bevatten persoonlijke paden en IDs)
.claude/settings.local.json
.claude/*.local.md

# Persoonlijke onderzoeksinhoud — niet delen, maar mapstructuur wel bewaren
.cache/candidates/*.md
llm-notes/*.md
llm-notes/annotations/*
!llm-notes/annotations/.gitkeep
wiki/syntheses/*
!wiki/syntheses/.gitkeep
.cache/*.vtt
.cache/*.mp3
.cache/*.txt
.cache/*.md
!.cache/.gitkeep

# Feedreader — gegenereerde output en persoonlijke leesgeschiedenis
.claude/score_log.jsonl
.claude/skip_queue.jsonl
.claude/read_queue.jsonl
.claude/transcript_cache/
.claude/article_cache/

# PURE cache — gedeelde directory, niet in git
.claude/pure_cache/

# Eenmalige hulpscripts — lokaal bewaren tot niet meer nodig, dan verwijderen
.claude/pure-backlog.py

# Python cache
**/__pycache__/
**/*.pyc

# OPML-exports (persoonlijke abonnementsdata, al verwerkt in feedreader-list.txt)
*.opml

# Syncthing configuratie (lokaal, apparaat-specifiek)
.stignore

# kytmanov/obsidian-llm-wiki — lokale state (vector DB, ingest-status)
.olw/
wiki/chroma
wiki/state.db

# Laat lege mappen zichtbaar via .gitkeep (zie per map)
.env
authoring
