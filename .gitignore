# macOS systeembestanden
.DS_Store
**/.DS_Store

# Obsidian-instellingen (machine-specifiek, niet deelbaar)
.obsidian/

# Claude Code lokale instellingen (bevatten persoonlijke paden en IDs)
.claude/settings.local.json

# Persoonlijke onderzoeksinhoud — niet delen, maar mapstructuur wel bewaren
literature/*.md
literature/annotations/*
!literature/annotations/.gitkeep
daily/*
!daily/.gitkeep
syntheses/*
!syntheses/.gitkeep
projects/*
!projects/.gitkeep
inbox/*.vtt
inbox/*.mp3
inbox/*.txt
inbox/*.md
!inbox/.gitkeep

# Phase 0 — gegenereerde output en persoonlijke leesgeschiedenis
.claude/phase0-serve/
.claude/score_log.jsonl
.claude/skip_queue.jsonl
.claude/transcript_cache/
.claude/article_cache/

# Python cache
**/__pycache__/
**/*.pyc

# OPML-exports (persoonlijke abonnementsdata, al verwerkt in phase0-feeds.txt)
*.opml

# Laat lege mappen zichtbaar via .gitkeep (zie per map)
.env
